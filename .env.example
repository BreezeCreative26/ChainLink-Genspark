# Supabase
# Find these in your Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only, never expose to the client. Used for privileged operations
# (e.g. admin scripts, service-role queries that bypass RLS deliberately).
SUPABASE_SERVICE_ROLE_KEY=

# Base URL of the app, used for constructing invite links, auth redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (transactional email — chain invitations). Server-only.
RESEND_API_KEY=
# Must be an address on a domain verified in your Resend account.
INVITE_EMAIL_FROM="ChainLink <invites@yourdomain.com>"

# --- Not yet used in this foundation step, reserved for later phases ---
# Stripe (Phase 4 — billing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
